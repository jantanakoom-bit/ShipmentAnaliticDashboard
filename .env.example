# Frontend HTTP port exposed by docker compose.
FRONTEND_PORT=5173

# Backend HTTP port. Used by the Express API and optional backend compose profile.
BACKEND_PORT=3001

# Build-time Vite API base URL baked into the frontend bundle.
# Use /api when a reverse proxy routes API traffic from the same origin.
VITE_API_BASE_URL=/api

# Runtime mode for the optional backend service.
NODE_ENV=development
