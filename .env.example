# Frontend HTTP port exposed by docker compose.
FRONTEND_PORT=5173

# Backend HTTP port. Used by the Express API and optional backend compose profile.
BACKEND_PORT=3001

# Build-time Vite API base URL baked into the frontend bundle.
# Use /api when a reverse proxy routes API traffic from the same origin.
VITE_API_BASE_URL=/api

# Runtime mode for the optional backend service.
NODE_ENV=development

# Authentication/session settings.
# Generate a long random value for SESSION_SECRET, at least 32 characters.
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
SESSION_COOKIE_NAME=shipment_session

# Google Sheets user database settings.
# Share the spreadsheet with GOOGLE_CLIENT_EMAIL from the service account.
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
USER_SHEET_NAME=Users

# Google Sheets data source (shipment detail data).
# Must match the tab name in the spreadsheet.
DATA_SHEET_NAME=Detail Data
